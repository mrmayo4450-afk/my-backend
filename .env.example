# Database (Supabase PostgreSQL)
SUPA_HOST=your-supabase-host
SUPA_USER=postgres.your-project-ref
SUPA_PASS=your-db-password
SUPA_DB=postgres
SUPA_PORT=5432

# Port the backend API listens on
PORT=5000

# When the frontend runs on a different origin, set this to allow CORS.
# Use * to allow all origins (not recommended in production).
FRONTEND_URL=https://your-frontend-domain.com

# Session secret
SESSION_SECRET=change-this-to-a-random-secret
